{
  "settings": {
    "analysis": {
      "tokenizer": {
        "products_nori_tokenizer": {
          "type": "nori_tokenizer",
          "decompound_mode": "discard",
          "user_dictionary_rules": [
            "아이앱",
            "스투시",
            "팔라스"
          ]
        }
      },
      "filter": {
        "products_search_synonym_filter": {
          "type": "synonym_graph",
          "synonyms": [
            "iab, 아이앱",
            "studio, 스튜디오, 스투디오",
            "stussy, 스투시, 스튜시",
            "nike, 나이키",
            "palace, 팔라스",
            "supreme, 슈프림",
            "블랙, 검정, 검정색, black",
            "화이트, 흰색, 하얀색, white",
            "후드, 후드티, 후디, hoodie",
            "스니커즈, 운동화, 스니커"
          ]
        }
      },
      "analyzer": {
        "products_index_analyzer": {
          "type": "custom",
          "tokenizer": "products_nori_tokenizer",
          "filter": [
            "lowercase",
            "nori_readingform"
          ]
        },
        "products_search_analyzer": {
          "type": "custom",
          "tokenizer": "products_nori_tokenizer",
          "filter": [
            "lowercase",
            "nori_readingform",
            "products_search_synonym_filter"
          ]
        }
      }
    }
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "_class": {
        "type": "keyword",
        "index": false
      },
      "productVariantId": {
        "type": "long"
      },
      "productId": {
        "type": "long"
      },
      "baseProductName": {
        "type": "text",
        "analyzer": "products_index_analyzer",
        "search_analyzer": "products_search_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "tags": {
        "type": "text",
        "analyzer": "products_index_analyzer",
        "search_analyzer": "products_search_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "variantName": {
        "type": "text",
        "analyzer": "products_index_analyzer",
        "search_analyzer": "products_search_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "productDescription": {
        "type": "text",
        "analyzer": "products_index_analyzer",
        "search_analyzer": "products_search_analyzer"
      },
      "brandId": {
        "type": "long"
      },
      "brandName": {
        "type": "text",
        "analyzer": "products_index_analyzer",
        "search_analyzer": "products_search_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "category": {
        "type": "keyword"
      },
      "color": {
        "type": "text",
        "analyzer": "products_index_analyzer",
        "search_analyzer": "products_search_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword"
          }
        }
      },
      "modelNumber": {
        "type": "keyword"
      },
      "price": {
        "type": "integer"
      },
      "productVariantStatus": {
        "type": "keyword"
      },
      "thumbnailUrl": {
        "type": "keyword",
        "index": false
      },
      "imageUrls": {
        "type": "keyword",
        "index": false
      },
      "options": {
        "type": "nested",
        "properties": {
          "optionId": {
            "type": "long"
          },
          "sku": {
            "type": "keyword"
          },
          "size": {
            "type": "keyword"
          },
          "additionalPrice": {
            "type": "integer"
          },
          "totalPrice": {
            "type": "integer"
          },
          "optionStatus": {
            "type": "keyword"
          },
          "availableStock": {
            "type": "integer"
          },
          "inStock": {
            "type": "boolean"
          }
        }
      },
      "totalAvailableStock": {
        "type": "integer"
      },
      "inStock": {
        "type": "boolean"
      },
      "descriptionVector": {
        "type": "dense_vector",
        "dims": 1536,
        "index": true,
        "similarity": "cosine"
      }
    }
  }
}
